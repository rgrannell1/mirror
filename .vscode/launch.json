{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File with Arguments",
      "type": "debugpy",
      "request": "launch",
      "program": "/home/rg/Code/mirror/cli.py",
      "console": "integratedTerminal",
      "args": "scan"
    },
    {
      "name": "Mirror Run (with DB cleanup)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/mirror/commands/run.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "stop-mirror-and-cleanup-db",
      "justMyCode": false
    },
    {
      "name": "Mirror Run (no cleanup)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/mirror/commands/run.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "stop-mirror",
      "justMyCode": false
    }
  ]
}
